<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>SurrealDB.Client.Sample.Api</RootNamespace>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <IsAspireApp>true</IsAspireApp>
    <UserSecretsId>surreal-sample-api</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="9.0.0" />
    <PackageReference Include="Scalar.AspNetCore" Version="2.4.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\SurrealDB.Client\SurrealDB.Client.csproj" />
    <ProjectReference Include="..\SurrealDB.Client.ServiceDefaults\SurrealDB.Client.ServiceDefaults.csproj" />
  </ItemGroup>

</Project>
